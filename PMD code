// 📸 Send photo to Telegram
void sendPhoto(camera_fb_t * fb) {
  clientTCP.stop();
  clientTCP.setInsecure();

  if (!clientTCP.connect("api.telegram.org", 443)) return;

  String head = "--ESP\r\nContent-Disposition: form-data; name=\"chat_id\"\r\n\r\n" + String(chatID) + "\r\n";
  head += "--ESP\r\nContent-Disposition: form-data; name=\"photo\"; filename=\"img.jpg\"\r\nContent-Type: image/jpeg\r\n\r\n";
  String tail = "\r\n--ESP--\r\n";

  clientTCP.println("POST /bot" + String(botToken) + "/sendPhoto HTTP/1.1");
  clientTCP.println("Host: api.telegram.org");
  clientTCP.println("Content-Type: multipart/form-data; boundary=ESP");
  clientTCP.print("Content-Length: ");
  clientTCP.println(head.length() + fb->len + tail.length());
  clientTCP.println();

  clientTCP.print(head);
  clientTCP.write(fb->buf, fb->len);
  clientTCP.print(tail);

  delay(500);
  clientTCP.stop();
}

// 🎮 Move servo
void moveServo(String cmd) {
  if (cmd == "left") servoPos -= 10;
  if (cmd == "right") servoPos += 10;

  servoPos = constrain(servoPos, 0, 180);
  myServo.write(servoPos);
}

// 🎮 Servo handler
esp_err_t servo_handler(httpd_req_t *req) {
  char* buf;
  size_t len = httpd_req_get_url_query_len(req) + 1;

  if (len > 1) {
    buf = (char*)malloc(len);
    httpd_req_get_url_query_str(req, buf, len);

    String cmd = String(buf);

    if (cmd.indexOf("left") >= 0) moveServo("left");
    if (cmd.indexOf("right") >= 0) moveServo("right");

    free(buf);
  }

  httpd_resp_send(req, NULL, 0);
  return ESP_OK;
}

// 🌐 HTML with STREAM + BUTTONS
esp_err_t index_handler(httpd_req_t *req) {
  const char* html = R"rawliteral(
  <!DOCTYPE html>
  <html>
  <head>
    <title>ESP32 CAM</title>
  </head>
  <body style="text-align:center;">
  
